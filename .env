# ─────────────────────────────────────────────────────────────
# .env — Configuración del Sistema de Presupuesto de Ingresos
# ─────────────────────────────────────────────────────────────

# Motor de base de datos: sqlserver | postgresql | mysql
DB_ENGINE=sqlserver

# ── Conexión ────────────────────────────────────────────────
DB_SERVER=localhost
DB_PORT=
DB_DATABASE=pptoBD
DB_USER=
DB_PASSWORD=
DB_SCHEMA=dbo

# ── Solo SQL Server ──────────────────────────────────────────
DB_DRIVER=ODBC Driver 17 for SQL Server
DB_WINDOWS_AUTH=True

# ── Flask ────────────────────────────────────────────────────
FLASK_PORT=5050

# Clave secreta para sesiones Flask (genera una con: python -c "import secrets; print(secrets.token_hex(32))")
APP_SECRET_KEY=
